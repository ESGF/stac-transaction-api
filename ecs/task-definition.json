{
  "family": "transaction-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "taskRoleArn": "arn:aws:iam::730335463484:role/esgf2-cluster-ecs-task",
  "executionRoleArn": "arn:aws:iam::730335463484:role/esgf2-cluster-ecs-task-execution",
  "containerDefinitions": [
    {
      "name": "transaction-api",
      "image": "REPLACED_BY_CI",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/esgf2-cluster/integration/transaction-api",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -f http://localhost:8000/healthcheck|| exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 15
      },
      "secrets": [
        {
          "name": "BOOTSTRAP_SERVERS",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:730335463484:secret:transaction-api/integration:BOOTSTRAP_SERVERS::"
        },
        {
          "name": "CONFLUENT_CLOUD_USERNAME",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:730335463484:secret:transaction-api/integration:CONFLUENT_CLOUD_USERNAME::"
        },
        {
          "name": "CONFLUENT_CLOUD_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:730335463484:secret:transaction-api/integration:CONFLUENT_CLOUD_PASSWORD::"
        },
        {
          "name": "GLOBUS_CLIENT_ID",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:730335463484:secret:transaction-api/integration:GLOBUS_CLIENT_ID::"
        },
        {
          "name": "GLOBUS_CLIENT_SECRET",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:730335463484:secret:transaction-api/integration:GLOBUS_CLIENT_SECRET::"
        },
        {
          "name": "TOPIC",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:730335463484:secret:transaction-api/integration:TOPIC::"
        }
      ]
    }
  ]
}
